{
  "name": "Fix the N+1",
  "image": "mcr.microsoft.com/devcontainers/ruby:1-3.3",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "postCreateCommand": "bundle install",
  "customizations": {
    "vscode": {
      "extensions": [
        "Shopify.ruby-lsp",
        "rebornix.ruby"
